{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri.conf.json",
  "productName": "Whisp",
  "version": "0.1.0",
  "identifier": "com.whisp.app",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Whisp Setup",
        "width": 540,
        "height": 720,
        "resizable": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
